# Base de datos PostgreSQL (local o remota)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ronsel?schema=public"

# JWT: secreto y expiración
JWT_SECRET="cambiar-en-produccion"
JWT_EXPIRES_IN="24h"

# Puerto del servidor backend
PORT=4000

# Origen permitido para CORS (frontend)
FRONTEND_URL="http://localhost:5173"
